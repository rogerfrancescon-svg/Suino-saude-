{
  "entities": {
    "VisitData": {
      "title": "VisitData",
      "description": "User specific visit history",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "userId": { "type": "string" },
        "producer": { "type": "string" },
        "farm": { "type": "string" },
        "batch": { "type": "string" },
        "date": { "type": "string" },
        "phase": { "type": "string" },
        "feed": { "type": "string" },
        "meds": { "type": "string" },
        "housingDate": { "type": "string" },
        "mortality": { "type": "number" },
        "totalAnimals": { "type": "number" },
        "temp": { "type": "string" },
        "humidity": { "type": "string" },
        "co2": { "type": "string" },
        "duration": { "type": "string" },
        "counts": { "type": "object" },
        "results": { "type": "object" },
        "notes": { "type": "string" },
        "images": { "type": "array" }
      },
      "required": ["id", "userId", "producer", "farm", "date", "phase"]
    }
  },
  "firestore": {
    "users/{userId}/history/{visitId}": {
      "schema": { "$ref": "#/entities/VisitData" },
      "description": "User history data"
    }
  }
}
